    "start:color-trail": "npm run build:color-trail && npm run serve:color-trail"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
