{
  "name": "fun-games",
  "private": true,
  "scripts": {
    "build:yarn-pull": "esbuild yarn-pull/main.jsx --bundle --format=esm --jsx=automatic --outfile=yarn-pull/dist/app.js",
    "serve:yarn-pull": "python3 -m http.server 4173 -d yarn-pull",
    "start:yarn-pull": "npm run build:yarn-pull && npm run serve:yarn-pull"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
